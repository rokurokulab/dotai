{
  "description": "PreToolUse git/gh guard (blocks high-regret mistakes; fail-open) plus PostToolUse lint hook (best-effort, never blocks).",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/guard-git.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post-edit-lint.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
